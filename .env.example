# ============================================================
#  SoportePost - Plantilla de Variables de Entorno
#  Copia este archivo como .env y rellena con tus valores
#  Este archivo SÍ puede subirse a Git (no tiene datos reales)
# ============================================================

# --- Base de Datos ---
DB_HOSTNAME=127.0.0.1
DB_PORT=5432
DB_USUARIO=postgres
DB_CLAVE=tu_password_aqui
DB_NOMBRE=SoportePost

# --- Directorio de Uploads ---
UPLOAD_BASE_DIR=C:\Documentos_SoportePost\

# --- Correo SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_AUTH=true
SMTP_USERNAME=tu_correo@dominio.com
SMTP_PASSWORD=tu_app_password_aqui
SMTP_SECURE=tls
SMTP_PORT=587

# --- Depuración (true para desarrollo, false para producción) ---
APP_DEBUG=true
